generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Company {
  id                    String   @id @default(cuid())
  name                  String
  legalNumber           String   @unique
  incorporationCountry  String
  website               String?
  createdAt             DateTime @default(now())

  products              Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  amount      Float
  amountUnit  String

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
} 

